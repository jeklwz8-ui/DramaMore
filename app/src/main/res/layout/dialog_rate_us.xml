<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/v_rate_dialog_dismiss"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#7A000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_rate_dialog_panel"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="18dp"
        android:paddingRight="16dp"
        android:paddingBottom="26dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/s_rate_dialog_title"
                android:textColor="@android:color/white"
                android:textSize="21sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_rate_close"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:contentDescription="@null"
                android:padding="2dp"
                android:src="@drawable/ic_close" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="@string/s_rate_dialog_subtitle"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="2dp"
            android:paddingRight="2dp">

            <LinearLayout
                android:id="@+id/ll_star_group_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_star_1"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:src="@drawable/collect_2" />

                <TextView
                    android:id="@+id/tv_rate_label_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/s_rate_label_1"
                    android:textColor="#FF684D"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_star_group_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_star_2"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:src="@drawable/collect_2" />

                <TextView
                    android:id="@+id/tv_rate_label_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/s_rate_label_2"
                    android:textColor="#FF684D"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_star_group_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_star_3"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:src="@drawable/collect_2" />

                <TextView
                    android:id="@+id/tv_rate_label_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/s_rate_label_3"
                    android:textColor="#FF684D"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_star_group_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_star_4"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:src="@drawable/collect_1" />

                <TextView
                    android:id="@+id/tv_rate_label_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/s_rate_label_4"
                    android:textColor="@android:color/white"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_star_group_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_star_5"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:src="@drawable/collect_1" />

                <TextView
                    android:id="@+id/tv_rate_label_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/s_rate_label_5"
                    android:textColor="@android:color/white"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/et_rate_feedback"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_rate_feedback_input"
            android:gravity="top|start"
            android:hint="@string/s_rate_feedback_hint"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:padding="12dp"
            android:textColor="#262626"
            android:textColorHint="#8E8E8E"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_rate_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_rate_submit_button"
            android:gravity="center"
            android:text="@string/s_rate_submit"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
