<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_follow_page"
    android:paddingLeft="14dp"
    android:paddingTop="40dp"
    android:paddingRight="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_collect_shorts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/s_my_collect_shorts"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_follow"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:overScrollMode="never" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_follow_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:background="@drawable/bg_follow_loading_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminate="true"
                android:indeterminateTint="#F44F3A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="加载中..."
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>